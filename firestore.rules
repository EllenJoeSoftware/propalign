rules_version = '2';

// Default-deny rules. Server-side reads/writes go through the Admin SDK,
// which bypasses these rules. Loosen if/when you add browser-side reads
// (e.g. a public listings page).
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
